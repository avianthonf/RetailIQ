{
  "family": "retailiq-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::610572473486:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::610572473486:role/retailiq-task-role",
  "containerDefinitions": [{
    "name": "retailiq-api",
    "image": "610572473486.dkr.ecr.us-east-1.amazonaws.com/retailiq:latest",
    "portMappings": [{"containerPort": 5000, "protocol": "tcp"}],
    "environment": [
      {"name": "SERVICE_ROLE", "value": "api"},
      {"name": "FLASK_ENV", "value": "production"}
    ],
    "secrets": [
      {"name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:us-east-1:610572473486:secret:retailiq/prod/db-url-UZwgrs"},
      {"name": "REDIS_URL", "valueFrom": "arn:aws:secretsmanager:us-east-1:610572473486:secret:retailiq/prod/redis-url-h6dZNR"},
      {"name": "CELERY_BROKER_URL", "valueFrom": "arn:aws:secretsmanager:us-east-1:610572473486:secret:retailiq/prod/celery-broker-url-fkqB00"},
      {"name": "SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:610572473486:secret:retailiq/prod/secret-key-pZqYnJ"},
      {"name": "JWT_PRIVATE_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:610572473486:secret:retailiq/prod/jwt-private-IeuEAW"},
      {"name": "JWT_PUBLIC_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:610572473486:secret:retailiq/prod/jwt-public-FY3L89"},
      {"name": "MAIL_USERNAME", "valueFrom": "arn:aws:secretsmanager:us-east-1:610572473486:secret:retailiq/prod/mail-username-LgXy28"},
      {"name": "MAIL_PASSWORD", "valueFrom": "arn:aws:secretsmanager:us-east-1:610572473486:secret:retailiq/prod/mail-password-owS9a5"}
    ],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/retailiq-api",
        "awslogs-region": "us-east-1",
        "awslogs-stream-prefix": "api"
      }
    },
    "healthCheck": {
      "command": ["CMD-SHELL", "python3 -c \"import socket; s=socket.socket(); s.connect(('localhost', 5000)); s.close();\" || exit 1"],
      "interval": 60,
      "timeout": 30,
      "retries": 5,
      "startPeriod": 120
    }
  }]
}
