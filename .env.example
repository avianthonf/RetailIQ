# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  RetailIQ — Environment Configuration                                      ║
# ║                                                                             ║
# ║  Copy this file to .env and fill in values:   cp .env.example .env          ║
# ║  NEVER commit .env itself — it contains secrets.                            ║
# ║                                                                             ║
# ║  Variables marked [REQUIRED] must be set for production.                    ║
# ║  Variables marked [OPTIONAL] have sensible defaults shown below.            ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ─────────────────────────────────────────────────────────────────────────────
# 1. APPLICATION
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Flask environment. Controls debug mode, SQL echo, and security
# checks. Must be "production" in deployed environments.
#   development  → SQL echo on, auto-generates JWT keys, relaxed secret check
#   production   → enforces strong SECRET_KEY, disables debug
FLASK_ENV=development

# [REQUIRED] WSGI entry point (used by docker-compose / gunicorn).
FLASK_APP=wsgi.py

# [OPTIONAL] Comma-separated list of allowed CORS origins.
# Leave empty for no CORS (API-only), or * for all origins (dev only!).
# Example: https://app.retailiq.in,https://admin.retailiq.in
CORS_ORIGINS=


# ─────────────────────────────────────────────────────────────────────────────
# 2. DATABASE (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Full PostgreSQL connection URI.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# In production use a managed database (RDS, Cloud SQL, etc.) with SSL:
#   postgresql://retailiq:StR0nGP@ss@db.internal:5432/retailiq?sslmode=require
DATABASE_URL=postgresql://retailiq:retailiq@postgres:5432/retailiq

# [OPTIONAL] Seconds to wait for the database to become available on startup.
# The wait_for_db.py script uses these before running migrations.
DB_WAIT_TIMEOUT=60
DB_WAIT_INTERVAL=2


# ─────────────────────────────────────────────────────────────────────────────
# 3. REDIS & CELERY
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Redis connection URI for caching, rate-limiting, and distributed
# locks. Uses DB 0 by default.
REDIS_URL=redis://redis:6379/0

# [REQUIRED] Celery broker URI. Should be a different Redis DB (DB 1)
# to keep broker traffic separate from cache/locks.
CELERY_BROKER_URL=redis://redis:6379/1


# ─────────────────────────────────────────────────────────────────────────────
# 4. SECURITY & AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Flask secret key. Used for CSRF protection, session signing,
# and Fernet-derived key for WhatsApp token encryption.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# ⚠  In production the app will REFUSE TO START if this is a known default.
SECRET_KEY=dev-secret-change-in-production

# [REQUIRED for production] RSA key pair for JWT signing / verification.
# In development, keys are auto-generated in memory.
# In production, paste the PEM content inline (replace real newlines with \n)
# or mount key files and set the path instead.
#
# Generate with:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
#
# Then paste inline (bash-style multiline):
#   JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEp...\n-----END RSA PRIVATE KEY-----"
#   JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBI...\n-----END PUBLIC KEY-----"
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# 5. GUNICORN (WSGI SERVER)
# ─────────────────────────────────────────────────────────────────────────────
# These only apply when the app is served via gunicorn (production).
# The dev docker-compose already sets sensible defaults.

# [OPTIONAL] Bind address. Default: 0.0.0.0:5000
GUNICORN_BIND=0.0.0.0:5000

# [OPTIONAL] Worker count. Formula: min(multiprocessing.cpu_count() * 2 + 1, MAX).
# Set explicitly if your container has cgroup CPU limits.
GUNICORN_MAX_WORKERS=4

# [OPTIONAL] Threads per worker (gthread worker class).
GUNICORN_THREADS=4

# [OPTIONAL] Request timeout in seconds. Increase for OCR uploads.
GUNICORN_TIMEOUT=120

# [OPTIONAL] Log verbosity: debug, info, warning, error, critical.
GUNICORN_LOG_LEVEL=info

# [OPTIONAL] Restart workers after this many requests to prevent memory leaks.
GUNICORN_MAX_REQUESTS=2000

# [OPTIONAL] Trusted reverse-proxy IPs for X-Forwarded-For.
# Set to your load balancer IP(s) in production, e.g. "10.0.0.0/8"
GUNICORN_FORWARDED_ALLOW_IPS=*


# ─────────────────────────────────────────────────────────────────────────────
# 6. WHATSAPP BUSINESS API (Meta Cloud API)
# ─────────────────────────────────────────────────────────────────────────────
# Required only if you enable the WhatsApp alerts module.
# Per-store access tokens are encrypted at rest with Fernet (derived from
# SECRET_KEY) — these env vars are NOT needed at the app level; they are
# configured per-store via PUT /api/v1/whatsapp/config.

# [OPTIONAL] Set to "true" to skip actual HTTP calls to Meta's API.
# Useful for development and testing.
WHATSAPP_DRY_RUN=true


# ─────────────────────────────────────────────────────────────────────────────
# 7. GST / TAX
# ─────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Directory where compiled GSTR-1 JSON files are written.
# Default: /tmp/gstr1. In production, mount a persistent volume.
GSTR1_OUTPUT_DIR=/tmp/gstr1


# ─────────────────────────────────────────────────────────────────────────────
# 8. POSTGRES CONTAINER (docker-compose only)
# ─────────────────────────────────────────────────────────────────────────────
# These are consumed by the postgres Docker image, NOT by the app itself.
# Change them in docker-compose.yml or override here.

POSTGRES_USER=retailiq
POSTGRES_PASSWORD=retailiq
POSTGRES_DB=retailiq
