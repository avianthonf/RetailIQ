# ============================================================================
# RetailIQ Environment Variables
# Copy to .env and fill in values: cp .env.example .env
# ============================================================================

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://retailiq:retailiq@postgres:5432/retailiq

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ── Security (generate real values for production) ──────────────────────────
SECRET_KEY=dev-secret-change-in-production
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── External Services (optional in dev) ─────────────────────────────────────
FCM_CREDENTIALS_PATH=
OTP_API_KEY=
CLOUDFLARE_R2_BUCKET=
